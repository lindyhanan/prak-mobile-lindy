<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#1A237E"
    tools:context=".pertemuan2.SecondActivity">

    <View
        android:layout_width="400dp"
        android:layout_height="400dp"
        android:layout_marginTop="-150dp"
        android:layout_marginEnd="-150dp"
        android:alpha="0.1"
        android:background="@android:drawable/presence_online"
        android:backgroundTint="#FF4081"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <View
        android:layout_width="300dp"
        android:layout_height="300dp"
        android:layout_marginStart="-100dp"
        android:layout_marginBottom="-100dp"
        android:alpha="0.1"
        android:background="@android:drawable/presence_online"
        android:backgroundTint="#00E676"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent" />

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="32dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintTop_toTopOf="parent">

        <TextView
            android:id="@+id/textView4"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Halo Mahasiswa!"
            android:textColor="#FFFFFF"
            android:textSize="14sp"
            android:letterSpacing="0.1"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/textTagline"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:text="Siap Taklukkan\nKuliah Hari Ini?"
            android:textColor="#FFFFFF"
            android:textSize="36sp"
            android:lineSpacingExtra="4dp"
            android:textStyle="bold" />

        <View
            android:layout_width="60dp"
            android:layout_height="6dp"
            android:layout_marginTop="24dp"
            android:background="#FFC107" />

        <TextView
            android:id="@+id/textNama"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="48dp"
            android:text="IDENTITAS KAMU"
            android:textColor="#9FA8DA"
            android:textSize="12sp"
            android:letterSpacing="0.2"
            android:textStyle="bold" />

        <EditText
            android:id="@+id/inputNama"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:backgroundTint="#FFC107"
            android:hint="Ketik nama di sini..."
            android:textColorHint="#5C6BC0"
            android:textColor="#FFFFFF"
            android:textSize="20sp"
            android:inputType="textPersonName" />

        <Button
            android:id="@+id/btnSubmit"
            android:layout_width="match_parent"
            android:layout_height="65dp"
            android:layout_marginTop="40dp"
            android:backgroundTint="#FFC107"
            android:text="MULAI SEKARANG!"
            android:textColor="#1A237E"
            android:textSize="18sp"
            android:textStyle="bold"
            app:cornerRadius="4dp" />

    </LinearLayout>

</androidx.constraintlayout.widget.ConstraintLayout>